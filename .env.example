# Phishing Risk Scorer v2 — Variables d'environnement
# Copiez ce fichier en ".env" et renseignez vos valeurs.

# Clé API VirusTotal (optionnel — active la vérification de réputation +50 pts)
# Obtenez une clé gratuite sur https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Chemin de la base de données SQLite (défaut : ./phishing_history.db)
DATABASE_PATH=./phishing_history.db

# Environnement Flask : development | production
FLASK_ENV=development

# Clé secrète Flask (générez avec : python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme_generate_a_strong_secret_key

# Port d'écoute (défaut : 5000)
PORT=5000
