{
  "manifest_version": 3,
  "name": "Phishing Risk Scorer",
  "version": "1.0.0",
  "description": "Analyse instant des emails pour phishing",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://mail.google.com/*",
    "*://outlook.live.com/*",
    "*://outlook.office.com/*",
    "*://mail.yahoo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://mail.google.com/*",
        "*://outlook.live.com/*",
        "*://outlook.office.com/*",
        "*://mail.yahoo.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Phishing Risk Scorer"
  }
}